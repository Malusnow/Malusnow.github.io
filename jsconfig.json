{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": false, 
    "allowJs": true,
    "checkJs": false 
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}